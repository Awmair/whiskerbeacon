---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('insights', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const dateFmt = (d) => new Date(d).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });

const schema = {
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "WhiskerBeacon Insights",
  "description": "Practical guides on AI automation for independent veterinary clinics: missed-call recovery, no-show reduction, lapsed-patient recall, and front-desk efficiency.",
  "url": "https://whiskerbeacon.com/insights/"
};
---
<BaseLayout title="Insights | AI for independent vet clinics | WhiskerBeacon" description="Practical, no-fluff guides on putting AI to work in an independent vet clinic: catching missed calls, killing no-shows, recovering lapsed patients, and freeing up the front desk." jsonld={schema}>
  <section class="band insights-hero">
    <div class="wrap">
      <div class="band-head reveal">
        <div class="eyebrow">Insights</div>
        <h2>Plain-English guides for the <em>busy front desk.</em></h2>
        <p>No hype, no jargon. Just what actually works when you put AI to work in an independent vet clinic.</p>
      </div>
      {posts.length === 0 && <p class="insights-empty">First articles landing shortly. Check back soon.</p>}
      <div class="insights-grid">
        {posts.map((post) => (
          <a class="insight-card reveal" href={`/insights/${post.slug}/`}>
            {post.data.heroImage && <div class="ic-photo"><img src={post.data.heroImage} alt={post.data.title} /></div>}
            <div class="ic-body">
              <div class="ic-meta">
                {post.data.tags && post.data.tags.length > 0 && <span class="ic-tag">{post.data.tags[0]}</span>}
                <span class="ic-date">{dateFmt(post.data.pubDate)}</span>
              </div>
              <h3>{post.data.title}</h3>
              <p>{post.data.description}</p>
              <span class="ic-read">Read <span class="arr">→</span></span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
