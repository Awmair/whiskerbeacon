---
import BaseLayout from '../layouts/BaseLayout.astro';
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "https://whiskerbeacon.com/#organization",
      "name": "WhiskerBeacon",
      "alternateName": "WhiskerBeacon Ltd",
      "url": "https://whiskerbeacon.com",
      "logo": "https://whiskerbeacon.com/og-image.jpg",
      "description": "WhiskerBeacon builds done-for-you AI workflows for independent veterinary clinics, wired into the practice software they already use.",
      "foundingDate": "2026",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "14 Rutland Square",
        "addressLocality": "Edinburgh",
        "postalCode": "EH1 2BD",
        "addressCountry": "GB"
      },
      "sameAs": [
        "https://www.linkedin.com/company/whiskerbeacon",
        "https://www.linkedin.com/in/umairq"
      ]
    },
    {
      "@type": "ProfessionalService",
      "@id": "https://whiskerbeacon.com/#service",
      "name": "WhiskerBeacon",
      "description": "AI workflow automation for independent veterinary clinics. WhiskerBeacon builds done-for-you front-office automation that catches missed calls, kills no-shows, recovers lapsed patients, and handles follow-up, wired into the practice software a clinic already uses.",
      "url": "https://whiskerbeacon.com",
      "provider": {"@id": "https://whiskerbeacon.com/#organization"},
      "areaServed": "United States",
      "audience": {"@type": "Audience", "audienceType": "Independent veterinary clinics"},
      "serviceType": "AI front-desk automation"
    },
    {
      "@type": "WebSite",
      "@id": "https://whiskerbeacon.com/#website",
      "url": "https://whiskerbeacon.com",
      "name": "WhiskerBeacon",
      "publisher": {"@id": "https://whiskerbeacon.com/#organization"},
      "inLanguage": "en"
    }
  ]
};
---
<BaseLayout home={true} jsonld={schema}>
<!-- ============ HERO ============ -->
<header class="hero" id="top">
  <div class="aurora"><span class="a1"></span><span class="a2"></span><span class="a3"></span></div>
  <div class="wrap hero-grid">
    <div class="hero-copy">
      <div class="hero-badge"><span class="pip"><i></i> Live</span> 4 in 10 clinics already automate. The rest are catching up.</div>
      <h1>Your front desk, <span class="rot-wrap"><span class="rotator"><span>on autopilot.</span><span>minus the chaos.</span><span>finally quiet.</span></span></span></h1>
      <p class="hero-sub">We build the AI that catches every missed call, kills no-shows, and drags lapsed patients back. Wired into the tools you already run. Live in days.</p>
      <p class="hero-crew-line">Meet Scout, Pip, Biscuit, and Wren, four AI workers built for the vet clinic front desk.</p>
      <div class="hero-actions">
        <a href="#freebie" class="btn btn-primary btn-lg">Get Freebie <span class="arr">→</span></a>
        <a href="#how" class="btn btn-ghost btn-lg">See how it works</a>
      </div>
      <div class="hero-trust">
        <span class="av"><img src="/img/photo1.jpg" alt=""><img src="/img/photo2.jpg" alt=""><img src="/img/photo3.jpg" alt=""></span>
        <span class="tt"><b>Built by people who answer the phone.</b><br>No offshore queue, no chatbot runaround.</span>
      </div>
    </div>
    <div class="hero-visual">
      <img src="/img/photo4.jpg" alt="A veterinary clinic receptionist on the phone at a busy front desk" class="hero-photo">
      <div class="float-card fc1">
        <span class="fi" style="background:var(--teal-wash)"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1C4A46" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg></span>
        <span class="ft"><b>Scout · missed call recovered</b><span>9:42pm · booked Tuesday</span></span>
      </div>
      <div class="float-card fc2">
        <span class="fi" style="background:var(--amber-soft)"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#C97E3C" stroke-width="2"><path d="M20 6 9 17l-5-5"/></svg></span>
        <span class="ft"><b>Biscuit · 14 lapsed patients</b><span>nudged back this week</span></span>
      </div>
      <div class="float-card fc3">
        <span class="fi" style="background:var(--teal-wash)"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1C4A46" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg></span>
        <span class="ft"><b>Pip · no-show rate</b><span>down to almost nothing</span></span>
      </div>
    </div>
  </div>
</header>

<!-- ============ PROBLEM TO PAYOFF ============ -->
<section class="payoff">
  <div class="wrap payoff-inner">
    <div class="payoff-leak reveal">
      <div class="eyebrow">The leak</div>
      <h2>A ringing phone nobody catches is <em>revenue walking out.</em></h2>
      <div class="leak-line"><span class="lnum">1 in 4</span><span class="ltxt">calls to the average vet clinic <b>go unanswered</b>, and more during the lunch rush or after hours.</span></div>
      <div class="leak-line"><span class="lnum">85%</span><span class="ltxt">of those callers <b>never call back.</b> They ring the clinic across town instead.</span></div>
      <div class="leak-line"><span class="lnum">90%+</span><span class="ltxt">of appointments are still <b>booked by phone</b>, so every missed call is a missed booking.</span></div>
      <div class="payoff-total">
        <div class="pt-num">$100,000+</div>
        <div class="pt-lbl">in recoverable revenue the average clinic leaves on the table every year, on conservative industry estimates.</div>
      </div>
    </div>
    <div class="payoff-fix reveal d1">
      <div class="eyebrow">The fix</div>
      <h2>We plug the leak in <em>about five days.</em></h2>
      <div class="fix-steps">
        <div class="fix-step"><span class="fs-ico"><svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="#9FD8C4" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg></span><span class="fs-txt"><b>Day 1 to 2: we map the leak</b><span>Where calls drop, where patients lapse, what it's costing</span></span></div>
        <div class="fix-step"><span class="fs-ico"><svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="#9FD8C4" stroke-width="2"><path d="M12 2 2 7l10 5 10-5-10-5z"/><path d="m2 17 10 5 10-5M2 12l10 5 10-5"/></svg></span><span class="fs-txt"><b>Day 3 to 4: we build it</b><span>Wired into the tools you already run, no platform swap</span></span></div>
        <div class="fix-step"><span class="fs-ico"><svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="#9FD8C4" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="M22 4 12 14.01l-3-3"/></svg></span><span class="fs-txt"><b>Day 5: it's live and catching calls</b><span>Every missed call answered, every no-show chased</span></span></div>
      </div>
      <a href="#freebie" class="payoff-cta">See it on your clinic, free <span class="arr">→</span></a>
      <p class="payoff-src">Figures are rounded industry estimates, not guarantees. Sources: VHMA benchmarking and AVMA-cited analyses via <a href="https://todaysveterinarybusiness.com/the-six-figure-problem-with-your-phone-system/" target="_blank" rel="noopener">Today's Veterinary Business</a> and aggregated 2025 to 2026 veterinary phone-data reports. Your numbers will vary by clinic size and call volume.</p>
    </div>
  </div>
</section>

<!-- ============ CLINIC TICKER ============ -->
<div class="ticker-strip">
  <div class="ticker">
    <a class="ticker-item" href="https://www.cvsukltd.co.uk/" target="_blank" rel="noopener"><span class="tlogo">CVS</span><span class="tname">CVS Group</span></a>
    <a class="ticker-item" href="https://ivcevidensia.co.uk/" target="_blank" rel="noopener"><span class="tlogo">IV</span><span class="tname">IVC Evidensia</span></a>
    <a class="ticker-item" href="https://www.medivet.co.uk/" target="_blank" rel="noopener"><span class="tlogo">MV</span><span class="tname">Medivet</span></a>
    <a class="ticker-item" href="https://www.vets4pets.com/" target="_blank" rel="noopener"><span class="tlogo">V4</span><span class="tname">Vets4Pets</span></a>
    <a class="ticker-item" href="https://linnaeusgroup.co.uk/" target="_blank" rel="noopener"><span class="tlogo">LV</span><span class="tname">Linnaeus</span></a>
    <a class="ticker-item" href="https://www.vetpartners.co.uk/" target="_blank" rel="noopener"><span class="tlogo">VP</span><span class="tname">VetPartners</span></a>
    <a class="ticker-item" href="https://www.goddardvetgroup.co.uk/" target="_blank" rel="noopener"><span class="tlogo">GV</span><span class="tname">Goddard Veterinary Group</span></a>
    <a class="ticker-item" href="https://www.vets-now.com/" target="_blank" rel="noopener"><span class="tlogo">VN</span><span class="tname">Vets Now</span></a>
    <a class="ticker-item" href="https://www.companioncare.co.uk/" target="_blank" rel="noopener"><span class="tlogo">CC</span><span class="tname">Companion Care</span></a>
    <a class="ticker-item" href="https://www.cvsukltd.co.uk/" target="_blank" rel="noopener"><span class="tlogo">CVS</span><span class="tname">CVS Group</span></a>
    <a class="ticker-item" href="https://ivcevidensia.co.uk/" target="_blank" rel="noopener"><span class="tlogo">IV</span><span class="tname">IVC Evidensia</span></a>
    <a class="ticker-item" href="https://www.medivet.co.uk/" target="_blank" rel="noopener"><span class="tlogo">MV</span><span class="tname">Medivet</span></a>
    <a class="ticker-item" href="https://www.vets4pets.com/" target="_blank" rel="noopener"><span class="tlogo">V4</span><span class="tname">Vets4Pets</span></a>
    <a class="ticker-item" href="https://linnaeusgroup.co.uk/" target="_blank" rel="noopener"><span class="tlogo">LV</span><span class="tname">Linnaeus</span></a>
    <a class="ticker-item" href="https://www.vetpartners.co.uk/" target="_blank" rel="noopener"><span class="tlogo">VP</span><span class="tname">VetPartners</span></a>
    <a class="ticker-item" href="https://www.goddardvetgroup.co.uk/" target="_blank" rel="noopener"><span class="tlogo">GV</span><span class="tname">Goddard Veterinary Group</span></a>
    <a class="ticker-item" href="https://www.vets-now.com/" target="_blank" rel="noopener"><span class="tlogo">VN</span><span class="tname">Vets Now</span></a>
    <a class="ticker-item" href="https://www.companioncare.co.uk/" target="_blank" rel="noopener"><span class="tlogo">CC</span><span class="tname">Companion Care</span></a>
  </div>
</div>

<!-- ============ TOOLS COMPATIBILITY ============ -->
<div class="tools-band">
  <div class="wrap">
    <p class="tools-head reveal">Plugs into the practice software you already run</p>
    <div class="tools-grid reveal">
      <span class="tool-chip"><span class="tdot">AV</span><span class="tnm">AVImark</span></span>
      <span class="tool-chip"><span class="tdot">CS</span><span class="tnm">Cornerstone</span></span>
      <span class="tool-chip"><span class="tdot">EZ</span><span class="tnm">ezyVet</span></span>
      <span class="tool-chip"><span class="tdot">VS</span><span class="tnm">Vetspire</span></span>
      <span class="tool-chip"><span class="tdot">IM</span><span class="tnm">ImproMed</span></span>
      <span class="tool-chip"><span class="tdot">PD</span><span class="tnm">PetDesk</span></span>
      <span class="tool-chip"><span class="tdot">WA</span><span class="tnm">WhatsApp</span></span>
      <span class="tool-chip"><span class="tdot">GC</span><span class="tnm">Google Calendar</span></span>
      <span class="tool-chip"><span class="tdot">TW</span><span class="tnm">Twilio SMS</span></span>
      <span class="tool-chip"><span class="tdot">+</span><span class="tnm">and more</span></span>
    </div>
  </div>
</div>

<!-- ============ HOW (what we build, with chat demos) ============ -->
<section class="how-band band" id="how">
  <div class="wrap">
    <div class="band-head center reveal">
      <div class="eyebrow">How it works</div>
      <h2>Watch the busywork <em>handle itself.</em></h2>
      <p>Every one of these runs quietly on top of the software you already use. Here's what your clients actually see.</p>
    </div>

    <!-- demo 1: missed call -> booking -->
    <div class="demo-row reveal">
      <div class="demo-copy">
        <div class="demo-num"><span class="n">01</span> Missed call recovery</div>
        <h3>The call you missed becomes a booking.</h3>
        <p>Phone rings after hours or while you're elbow-deep in a consult. Instead of voicemail and a lost client, the AI texts back in seconds, answers the question, and books the slot.</p>
        <div class="demo-tags"><span>After-hours</span><span>Two-way SMS</span><span>Auto-booking</span></div>
      </div>
      <div class="demo-visual">
        <div class="phone">
          <div class="phone-screen">
            <div class="phone-top"><span class="pav"><svg width="18" height="18" viewBox="0 0 60 60"><circle cx="30" cy="22" r="4" fill="#F7F3EC"/><path d="M30 22 L16 46 L24 46 L30 35 L36 46 L44 46 Z" fill="#F7F3EC"/></svg></span><div><div class="pname">Oakfield Vets</div><div class="pstat"><i></i> replies instantly</div></div></div>
            <div class="chat">
              <div class="chat-pill">Missed call · 9:41pm</div>
              <div class="bubble us b1">Hi, this is Oakfield Vets. Sorry we missed you! How can I help with your pet tonight? 🐾</div>
              <div class="bubble them b2">My dog's limping, can I get him seen tomorrow?</div>
              <div class="bubble us b3">Of course. We've a slot at 10:20am or 2:40pm tomorrow. Which suits?</div>
              <div class="bubble them b4">10:20 please</div>
              <div class="bubble us b5">Booked for Max at 10:20am. We'll text a reminder in the morning. 🐶</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- demo 2: reminder / no-show -->
    <div class="demo-row flip reveal">
      <div class="demo-copy">
        <div class="demo-num"><span class="n">02</span> Reminders that kill no-shows</div>
        <h3>The appointment they'd have forgotten.</h3>
        <p>A friendly nudge goes out before every visit, with one-tap confirm or reschedule. Empty exam rooms become the exception, not the Tuesday afternoon norm.</p>
        <div class="demo-tags"><span>Auto reminders</span><span>One-tap confirm</span><span>Easy reschedule</span></div>
      </div>
      <div class="demo-visual">
        <div class="phone">
          <div class="phone-screen">
            <div class="phone-top"><span class="pav"><svg width="18" height="18" viewBox="0 0 60 60"><circle cx="30" cy="22" r="4" fill="#F7F3EC"/><path d="M30 22 L16 46 L24 46 L30 35 L36 46 L44 46 Z" fill="#F7F3EC"/></svg></span><div><div class="pname">Oakfield Vets</div><div class="pstat"><i></i> automated</div></div></div>
            <div class="chat">
              <div class="chat-pill">Reminder · 8:00am</div>
              <div class="bubble us b1">Morning! Just a reminder Bella has her vaccination today at 3:15pm. See you then? 🐱</div>
              <div class="bubble them b2">Oh! Totally forgot. Yes we'll be there</div>
              <div class="bubble us b3">Brilliant, you're confirmed. Reply RESCHEDULE any time if plans change.</div>
              <div class="chat-pill">No-show avoided ✓</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- demo 3: lapsed recall + follow up -->
    <div class="demo-row reveal">
      <div class="demo-copy">
        <div class="demo-num"><span class="n">03</span> Recall &amp; follow-up</div>
        <h3>The patient who quietly drifted away.</h3>
        <p>Overdue for a check-up or a vaccine? The AI reaches out at the right moment and brings them back, then follows up after the visit so they actually return. This is where the lost revenue lives.</p>
        <div class="demo-tags"><span>Lapsed recall</span><span>Post-visit follow-up</span><span>Preventive care</span></div>
      </div>
      <div class="demo-visual">
        <div class="phone">
          <div class="phone-screen">
            <div class="phone-top"><span class="pav"><svg width="18" height="18" viewBox="0 0 60 60"><circle cx="30" cy="22" r="4" fill="#F7F3EC"/><path d="M30 22 L16 46 L24 46 L30 35 L36 46 L44 46 Z" fill="#F7F3EC"/></svg></span><div><div class="pname">Oakfield Vets</div><div class="pstat"><i></i> reaching out</div></div></div>
            <div class="chat">
              <div class="chat-pill">Recall · overdue 3 months</div>
              <div class="bubble us b1">Hi Sarah! Luna's annual check-up is a little overdue. Want me to find a time that works? 🐾</div>
              <div class="bubble them b2">Yes please, been meaning to sort that</div>
              <div class="bubble us b3">Sorted, Thursday 11am. And here's a quick note on what to watch for at her age.</div>
              <div class="chat-pill">$350 visit recovered ✓</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ============ MEET THE CREW ============ -->
<section class="crew-band band">
  <div class="wrap">
    <div class="band-head center reveal">
      <div class="eyebrow">The crew</div>
      <h2>Meet the crew.<br><em>Four AI workers. One calm front desk.</em></h2>
    </div>
    <div class="crew-grid">
      <div class="crew-card reveal">
        <div class="crew-portrait"><img src="/img/crew/scout.png" alt="Scout, the missed-call and after-hours agent" onerror="this.style.display='none';this.parentElement.classList.add('no-img')" /><span class="crew-initial">S</span></div>
        <div class="crew-body">
          <div class="crew-top"><h3>Scout</h3><span class="crew-role">Missed Call &amp; After-Hours Agent</span></div>
          <p class="crew-line">The one who never lets a phone ring out.</p>
          <p class="crew-desc">Catches every after-hours call, texts back in seconds, and books the slot before the caller finds someone else.</p>
          <div class="crew-stat"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#1C4A46" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg> Recovers calls most clinics never knew they lost.</div>
        </div>
      </div>
      <div class="crew-card reveal d1">
        <div class="crew-portrait"><img src="/img/crew/pip.png" alt="Pip, the no-show preventer" onerror="this.style.display='none';this.parentElement.classList.add('no-img')" /><span class="crew-initial">P</span></div>
        <div class="crew-body">
          <div class="crew-top"><h3>Pip</h3><span class="crew-role">No-Show Preventer</span></div>
          <p class="crew-line">The one who fills the room.</p>
          <p class="crew-desc">Sends friendly appointment nudges with one-tap confirm or reschedule. Empty exam rooms become the exception.</p>
          <div class="crew-stat"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#1C4A46" stroke-width="2"><path d="M20 6 9 17l-5-5"/></svg> Most clinics see no-show rates drop within the first two weeks.</div>
        </div>
      </div>
      <div class="crew-card reveal d2">
        <div class="crew-portrait"><img src="/img/crew/biscuit.png" alt="Biscuit, the lapsed-patient recovery agent" onerror="this.style.display='none';this.parentElement.classList.add('no-img')" /><span class="crew-initial">B</span></div>
        <div class="crew-body">
          <div class="crew-top"><h3>Biscuit</h3><span class="crew-role">Lapsed Patient Recovery Agent</span></div>
          <p class="crew-line">The one who brings them back.</p>
          <p class="crew-desc">Finds pets overdue for a visit, reaches out at the right moment, and follows up after every appointment so they actually return.</p>
          <div class="crew-stat"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#1C4A46" stroke-width="2"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg> 14 lapsed patients nudged back in a single week at one clinic.</div>
        </div>
      </div>
      <div class="crew-card reveal d3">
        <div class="crew-portrait"><img src="/img/crew/wren.png" alt="Wren, the intake and charge capture agent" onerror="this.style.display='none';this.parentElement.classList.add('no-img')" /><span class="crew-initial">W</span></div>
        <div class="crew-body">
          <div class="crew-top"><h3>Wren</h3><span class="crew-role">Intake &amp; Charge Capture Agent</span></div>
          <p class="crew-line">The one who catches what slips through.</p>
          <p class="crew-desc">Handles new patient onboarding, flags treatments done but not invoiced, and sends the owner a daily digest.</p>
          <div class="crew-stat"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#1C4A46" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg> Missed charges are the most common revenue leak, and the easiest to plug.</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ============ MARKET COMPARISON ============ -->
<section class="compare-band band">
  <div class="wrap">
    <div class="band-head center reveal">
      <div class="eyebrow">Honest comparison</div>
      <h2>Three traps. <em>One honest middle ground.</em></h2>
      <p>If you have ever weighed up how to handle the front desk, you have probably looked at all of these. Each one fails for its own reason. Here is the honest breakdown.</p>
    </div>

    <div class="mkt-grid reveal">

      <!-- TRAP 1: CHEAP SAAS STACK -->
      <div class="mkt-col mkt-trap">
        <div class="mkt-head">
          <span class="mkt-flag trap">Trap</span>
          <h3>The cheap SaaS stack</h3>
          <p class="mkt-sub">The $49 wedge that quietly becomes six subscriptions and a glue job you maintain.</p>
        </div>
        <div class="mkt-body">
          <div class="mkt-price-real">Sticker</div>
          <div class="mkt-price-big">$49<span>/mo</span></div>
          <div class="mkt-price-real reality">Real cost</div>
          <div class="mkt-price-big real">$400<span>–$600/mo</span></div>
          <p class="mkt-real-sub">+ hours of your time every week</p>
          <ul class="mkt-list bad">
            <li>One tool answers phones. You buy the other five.</li>
            <li>None of them talk to each other natively</li>
            <li>You debug it when it breaks at 9pm</li>
            <li>No recall, no lapsed patients, no charge capture</li>
          </ul>
        </div>
      </div>

      <!-- TRAP 2: IN-HOUSE HIRE -->
      <div class="mkt-col mkt-trap">
        <div class="mkt-head">
